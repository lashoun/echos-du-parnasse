
export function getSupabaseConfig() {
  // During build/static generation, env vars may not be available.
  // Return null so callers can skip Supabase calls gracefully.
  const url = process.env.NEXT_PUBLIC_SUPABASE_URL
  const key = process.env.NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
  if (!url || !key) return null

  return {
    url: url,
    publishableKey: key,
  }
}

/** Throws if env vars are missing — use in request handlers only. */
export function requireSupabaseConfig() {
  const config = getSupabaseConfig()
  if (!config) {
    throw new Error(
      'Missing env var: NEXT_PUBLIC_SUPABASE_URL or NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY',
    )
  }
  return config
}
